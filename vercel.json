{
  "version": 2,
  "cleanUrls": true,
  "outputDirectory": "frontend/dist",
  "functions": {
    "backend/app.js": {
      "runtime": "@vercel/node@20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/backend/app.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
