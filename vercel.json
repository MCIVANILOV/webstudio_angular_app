{
  "version": 2,
  "cleanUrls": true,
  "outputDirectory": "frontend/dist",
  "functions": {
    "backend/app.js": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/backend/app.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
