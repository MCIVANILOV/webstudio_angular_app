{
  "version": 2,
  "cleanUrls": true,
  "functions": {
    "api/app.js": {
      "runtime": "@vercel/node@canary"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/app.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
